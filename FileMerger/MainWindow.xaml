<Window x:Class="FileMerger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Merger" 
        Height="650" 
        Width="900"
        MinHeight="450"
        MinWidth="600"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Text Optimization Options" Margin="0,0,0,10" Padding="8">
            <StackPanel Orientation="Horizontal">
                <CheckBox Content="Remove empty lines" 
                          IsChecked="{Binding RemoveEmptyLines}"
                          Margin="0,0,20,0"
                          VerticalAlignment="Center"/>

                <CheckBox Content="Remove comments (//, ///, /* */)" 
                          IsChecked="{Binding RemoveComments}"
                          Margin="0,0,20,0"
                          VerticalAlignment="Center"/>

                <CheckBox Content="Remove extra spaces" 
                          IsChecked="{Binding RemoveExtraSpaces}"
                          Margin="0,0,20,0"
                          VerticalAlignment="Center"/>

                <CheckBox Content="Include file paths" 
                          IsChecked="{Binding IncludeFullPath}"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Add Files" 
                            Command="{Binding AddFilesCommand}"
                            Width="90"
                            Margin="0,0,5,0"
                            Padding="5"/>

                    <Button Content="Up" 
                            Command="{Binding MoveUpCommand}"
                            Width="40"
                            Margin="0,0,2,0"
                            Padding="5"
                            ToolTip="Move selected file up"/>

                    <Button Content="Down" 
                            Command="{Binding MoveDownCommand}"
                            Width="50"
                            Margin="0,0,5,0"
                            Padding="5"
                            ToolTip="Move selected file down"/>

                    <Button Content="Clear All" 
                            Command="{Binding ClearFilesCommand}"
                            Width="80"
                            Padding="5"/>
                </StackPanel>

                <Border Grid.Row="1" 
                        BorderBrush="LightGray" 
                        BorderThickness="2" 
                        CornerRadius="5"
                        Background="#FFF9F9F9">
                    <ListBox ItemsSource="{Binding Files}"
                             SelectedItem="{Binding SelectedFile}"
                             x:Name="FilesListBox"
                             SelectionMode="Single"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="5" Margin="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FileName}" 
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding FullPath}" 
                                                       FontSize="10" 
                                                       Foreground="Gray"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <Button Grid.Column="1" 
                                                Content="X" 
                                                Width="30" 
                                                Height="30"
                                                Command="{Binding DataContext.RemoveFileCommand, 
                                                        ElementName=FilesListBox}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove file"
                                                VerticalAlignment="Center"
                                                Foreground="Red"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" 
                          Width="5" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch"
                          Background="LightGray"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Merge" 
                            Command="{Binding MergeFilesCommand}"
                            Width="80"
                            Margin="0,0,5,0"
                            Padding="5"
                            IsEnabled="{Binding HasFiles}"/>

                    <Button Content="Copy" 
                            Command="{Binding CopyToClipboardCommand}"
                            Width="60"
                            Margin="0,0,5,0"
                            Padding="5"
                            ToolTip="Copy merged text to clipboard"/>

                    <Button Content="Save As..." 
                            Command="{Binding SaveToFileCommand}"
                            Width="80"
                            Padding="5"/>
                </StackPanel>

                <TextBox Grid.Row="1" 
                         Text="{Binding MergedText, Mode=OneWay}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Visible"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         BorderBrush="LightGray"
                         Padding="5"
                         MaxLines="50000"
                         UndoLimit="0"/>
            </Grid>
        </Grid>
    </Grid>
</Window>